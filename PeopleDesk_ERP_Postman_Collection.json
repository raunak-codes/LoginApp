{
  "info": {
    "name": "PeopleDesk ERP - Enterprise API Collection",
    "description": "Comprehensive API collection for PeopleDesk ERP system. Tests Auth, Employees, Leaves, Assets, and Health Monitoring. Designed with environment variables and automated test assertions.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth APIs",
      "item": [
        {
          "name": "Signup Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"System Administrator\",\n  \"email\": \"admin@peopledesk.com\",\n  \"password\": \"admin_secure_123\",\n  \"role\": \"admin\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/signup",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "signup"]
            }
          },
          "response": []
        },
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const responseJson = pm.response.json();",
                  "if (responseJson.token) {",
                  "    pm.environment.set(\"token\", responseJson.token);",
                  "}",
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Token is present\", function () {",
                  "    pm.expect(responseJson.token).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@peopledesk.com\",\n  \"password\": \"admin_secure_123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Employee APIs",
      "item": [
        {
          "name": "Create Employee Profile",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "{{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": 1,\n  \"department_id\": 1,\n  \"phone\": \"9876543210\",\n  \"address\": \"123 Enterprise Blvd, Suite 400\",\n  \"designation\": \"Principal Architect\",\n  \"salary\": 120000.00,\n  \"skill_ids\": [1, 2, 3]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/employees",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "employees"]
            }
          },
          "response": []
        },
        {
          "name": "Get Employees List (V1 Paginated & Sorted)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/employees?page=1&limit=10&sortBy=salary&sortOrder=DESC",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "employees"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "sortBy",
                  "value": "salary"
                },
                {
                  "key": "sortOrder",
                  "value": "DESC"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Employees List (V2 Evolution)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v2/employees?page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["api", "v2", "employees"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          },
          "response": []
        }
      ]
